---
/**
 * Skyline — six SVG city buildings, one per section.
 *
 * Ported from Skyline.jsx in the design_system/ui_kit prototype.
 * All SVG paths are verbatim from the prototype BUILDINGS array.
 * Each building is wrapped in an <a> linking to its section route.
 *
 * Viewbox: each building is 320px tall (BUILDING_VIEWBOX_H = 300 in
 * the prototype — all shapes bottom out at y=300, so the viewbox
 * effectively clips empty space above the buildings).
 *
 * Hover: translateY(-3px) + filter: saturate(1.1) brightness(1.04)
 *
 * Mobile (<700px): horizontal scroll-snap row; buildings stay at
 * canonical width — no scaling.
 */

const BUILDINGS = [
  {
    id: 'work',
    href: '/work',
    color: 'var(--c-work)',
    labelFg: 'var(--bone)',
    w: 130,
    ariaLabel: 'Work',
    shapes: `
      <rect x="30" y="180" width="100" height="120" />
      <rect x="8" y="140" width="24" height="160" />
      <polygon points="20,128 25,138 30,128 25,118" />
      <circle cx="20" cy="125" r="6" />
      <rect x="36" y="172" width="88" height="10" />
      <circle cx="42" cy="170" r="4" />
      <circle cx="56" cy="170" r="4" />
      <circle cx="70" cy="170" r="4" />
      <circle cx="84" cy="170" r="4" />
      <circle cx="98" cy="170" r="4" />
      <circle cx="112" cy="170" r="4" />
    `,
  },
  {
    id: 'art',
    href: '/art',
    color: 'var(--c-art)',
    labelFg: 'var(--char)',
    w: 140,
    ariaLabel: 'Art',
    shapes: `
      <rect x="10" y="280" width="120" height="20" />
      <rect x="18" y="260" width="104" height="20" />
      <rect x="22" y="180" width="96" height="80" />
      <polygon points="22,180 70,140 118,180" />
      <path d="M 53 140 A 17 17 0 0 1 87 140 Z" />
      <rect x="68" y="110" width="4" height="30" />
      <circle cx="70" cy="108" r="4" />
    `,
  },
  {
    id: 'games',
    href: '/games',
    color: 'var(--c-games)',
    labelFg: 'var(--bone)',
    w: 130,
    ariaLabel: 'Games',
    shapes: `
      <rect x="20" y="140" width="90" height="160" />
      <rect x="10" y="270" width="110" height="30" />
      <rect x="62" y="92" width="6" height="48" />
      <circle cx="65" cy="90" r="5" />
    `,
  },
  {
    id: 'music',
    href: '/music',
    color: 'var(--c-music)',
    labelFg: 'var(--char)',
    w: 130,
    ariaLabel: 'Music',
    shapes: `
      <rect x="15" y="180" width="100" height="120" />
      <polygon points="20,180 30,110 40,180" />
      <circle cx="30" cy="106" r="4" />
      <polygon points="90,180 100,110 110,180" />
      <circle cx="100" cy="106" r="4" />
      <polygon points="20,235 110,235 102,250 28,250" />
    `,
  },
  {
    id: 'writing',
    href: '/writing',
    color: 'var(--c-writing)',
    labelFg: 'var(--bone)',
    w: 130,
    ariaLabel: 'Writing',
    shapes: `
      <rect x="20" y="190" width="100" height="110" />
      <polygon points="20,190 70,150 120,190" />
      <rect x="90" y="160" width="14" height="36" />
      <rect x="86" y="156" width="22" height="6" />
    `,
  },
  {
    id: 'about',
    href: '/about',
    color: 'var(--c-about)',
    labelFg: 'var(--bone)',
    w: 120,
    ariaLabel: 'About',
    shapes: `
      <rect x="20" y="200" width="90" height="100" />
      <polygon points="14,200 30,160 100,160 116,200" />
      <rect x="63" y="125" width="4" height="40" />
      <polygon points="67,128 80,134 67,140" />
    `,
  },
];

const VIEWBOX_H = 300;
---

<div class="city">
  <div class="city-row">
    {BUILDINGS.map((b) => (
      <a
        href={b.href}
        class="city-building"
        aria-label={b.ariaLabel}
        style={`--building-color: ${b.color}; --label-fg: ${b.labelFg}; width: ${b.w}px;`}
        data-section={b.id}
      >
        <svg
          viewBox={`0 0 ${b.w} ${VIEWBOX_H}`}
          width={b.w}
          height={VIEWBOX_H}
          preserveAspectRatio="xMidYMax meet"
          aria-hidden="true"
          focusable="false"
        >
          <g fill={b.color} set:html={b.shapes} />
        </svg>
        <div class="city-label" style={`color: ${b.labelFg};`}>{b.ariaLabel.toLowerCase()}</div>
      </a>
    ))}
  </div>
  <div class="city-groundline" aria-hidden="true"></div>
</div>

<style>
  /* ---- Container ---- */
  .city {
    margin: 64px 0 0;
    position: relative;
  }

  /* ---- Building row ---- */
  .city-row {
    display: flex;
    align-items: flex-end;        /* all buildings sit on the baseline */
    justify-content: flex-start;  /* left-aligned, not centered */
    gap: 24px;
    padding: 0;
  }

  /* ---- Ground line below all buildings ---- */
  .city-groundline {
    height: 4px;
    background: var(--char);
    margin-top: 2px;
  }

  /* ---- Individual building link ---- */
  .city-building {
    display: block;
    position: relative;
    text-decoration: none;
    cursor: pointer;
    flex-shrink: 0;
    transition: transform var(--d-base) var(--ease-stand), filter var(--d-base) var(--ease-stand);
  }
  .city-building:hover {
    transform: translateY(-3px);
    filter: saturate(1.1) brightness(1.04);
    background: transparent;
  }
  /* Override global a:hover which would invert the building */
  .city-building:hover,
  .city-building:focus {
    background: transparent;
    color: inherit;
  }

  .city-building svg {
    display: block;
  }

  /* Halftone dot texture over the building — multiply blend so it
     only shows over the colored fills, not the transparent areas */
  .city-building::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: radial-gradient(var(--char) 0.7px, transparent 1.4px);
    background-size: 4px 4px;
    opacity: 0.14;
    mix-blend-mode: multiply;
  }

  /* Section label — positioned inside the building near the bottom */
  .city-label {
    position: absolute;
    bottom: 14px;
    left: 0;
    right: 0;
    text-align: center;
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 13px;
    line-height: 1;
    z-index: 2;
    pointer-events: none;
  }

  /* ---- Mobile: horizontal scroll-snap row ---- */
  @media (max-width: 700px) {
    .city-row {
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      /* Padding so first/last buildings have breathing room */
      padding: 0 24px;
      /* Don't let the row overflow the page body */
      margin: 0 -24px;
      /* Hide scrollbar — still scrollable */
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
    }
    .city-row::-webkit-scrollbar { display: none; }

    .city-building {
      scroll-snap-align: start;
      /* Buildings stay at canonical width — no scaling */
    }
  }
</style>
