---
/**
 * SectionHead — used by all section index pages.
 * Layout: huge Big Shoulders display title left, italic Newsreader blurb right.
 * 2px char rule below via border-bottom.
 *
 * Props:
 *   title  — section name (e.g. "work")
 *   blurb  — short italic line below/right of the title
 */

export interface Props {
  title: string;
  blurb: string;
}

const { title, blurb } = Astro.props;
---

<div class="section-head">
  <h1 class="section-title">{title}</h1>
  <p class="section-blurb">{blurb}</p>
</div>

<style>
  .section-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    border-bottom: 2px solid var(--char);
    padding-bottom: 12px;
    margin-bottom: 32px;
  }

  .section-title {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    font-size: clamp(40px, 6vw, 80px);
    line-height: 0.88;
    letter-spacing: -0.012em;
    margin: 0;
    color: var(--char);
  }

  .section-blurb {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 17px;
    color: var(--umber);
    max-width: 42ch;
    margin: 0 0 6px;
    text-align: right;
    line-height: 1.4;
  }

  @media (max-width: 600px) {
    .section-head {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }
    .section-blurb {
      text-align: left;
      max-width: none;
    }
  }
</style>
