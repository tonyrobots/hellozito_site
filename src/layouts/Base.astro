---
/**
 * Base layout — the site shell every page uses.
 * Renders Nav at top, <main> slot in the middle, Footer at bottom.
 *
 * Props:
 *   title       — <title> tag value. Defaults to 'hello, zito.'
 *   description — <meta description> content. Has a sensible site-wide default.
 *   image       — absolute URL or root-relative path for OG/Twitter image.
 *                 Defaults to '/og-image.png'.
 *   canonical   — canonical URL. Auto-derived from Astro.url if omitted.
 *   type        — OG type: 'website' (default) or 'article' (project/drawing detail pages)
 *   current     — current page slug for Nav active state (e.g. 'work')
 */

import '../styles/global.css';
import Analytics from '../components/Analytics.astro';
import Nav from '../components/Chrome/Nav.astro';
import Footer from '../components/Chrome/Footer.astro';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
  type?: 'website' | 'article';
  current?: string;
}

const {
  title = 'hello, zito.',
  description = "Tony Zito's personal portfolio — work, art, games, music.",
  image = '/og-image.png',
  type = 'website',
  current = '',
} = Astro.props;

// Canonical: use explicitly provided canonical, else derive from Astro.url.
// Astro.url is the full URL of the current page (requires site: in astro.config.mjs).
const canonical = Astro.props.canonical ?? Astro.url.href;

// OG image must be an absolute URL. If a root-relative path is given, prepend site origin.
const siteOrigin = Astro.url.origin;
const ogImage = image.startsWith('http') ? image : `${siteOrigin}${image}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Favicon — tomato square on bone bg, SVG for modern browsers -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!--
      Google Fonts as <link> instead of CSS @import for better performance.
      @import blocks rendering; <link rel="preconnect"> + <link rel="stylesheet">
      allows the browser to discover and fetch fonts in parallel with parsing.
      The @import in tokens.css is the legacy path — this replaces it for production.
      Tony Hand @font-face stays in tokens.css (local woff2, not a Google font).
    -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@500;700;800;900&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;0,6..72,700;1,6..72,400;1,6..72,500;1,6..72,600&family=Silkscreen:wght@400;700&family=Coral+Pixels&display=swap"
    />

    <!-- OpenGraph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="hello, zito." />

    <!-- Twitter card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Analytics (GA4 — production only) -->
    <Analytics />
  </head>
  <body>
    <Nav current={current} />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
