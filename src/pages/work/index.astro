---
/**
 * Work index — grid of ProjectCards sorted by order.
 * Cards link to /work/<slug> detail pages.
 */

import Base from '../../layouts/Base.astro';
import SectionHead from '../../components/SectionHead.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('work')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<Base
  title="work · hello, zito."
  description="Two decades of products, with a few embarrassments redacted. UX design, product management, and engineering from Tony Zito."
  current="work"
>
  <div class="container">
    <SectionHead
      title="work"
      blurb="two decades of products, with a few embarrassments redacted. tap any one for the longer version."
    />

    <div class="project-grid">
      {entries.map((entry) => (
        <ProjectCard
          title={entry.data.title}
          slug={entry.slug}
          period={entry.data.period}
          role={entry.data.role}
          blurb={entry.data.blurb}
          tags={entry.data.tags}
          coverColor={entry.data.cover.color}
          href={`/work/${entry.slug}`}
          sectionColor="var(--c-work)"
        />
      ))}
    </div>
  </div>
</Base>

<style>
  .container {
    max-width: 1140px;
    margin: 0 auto;
    padding: 64px 32px;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 22px;
  }

  @media (max-width: 600px) {
    .container { padding: 40px 20px; }
    .project-grid { grid-template-columns: 1fr; }
  }
</style>
