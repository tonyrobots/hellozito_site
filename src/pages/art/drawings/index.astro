---
/**
 * Drawings gallery index — thumbnail grid.
 * Each thumb links to /art/drawings/<n> for the stage view.
 * Grid: repeat(auto-fill, minmax(220px, 1fr)) per spec.
 */

import Base from '../../../layouts/Base.astro';
import { Image } from 'astro:assets';
import { drawings } from '../../../content/drawings/manifest';
---

<Base
  title="drawings · art · hello, zito."
  description="42 ink drawings by Tony Zito, 2020–ongoing. Small, titled, slightly serious."
  current="art"
>
  <div class="container">
    <!-- Section head -->
    <div class="gallery-head">
      <h1 class="gallery-title">drawings</h1>
      <p class="gallery-blurb">
        {drawings.length} ink drawings, 2020 — ongoing. small, titled, slightly serious.
      </p>
    </div>

    <!-- Thumbnail grid -->
    <div class="thumb-grid">
      {drawings.map((d) => (
        <a class="thumb-item" href={`/art/drawings/${d.n}`} title={d.title}>
          <Image
            src={d.image}
            alt={d.title}
            widths={[220, 440]}
            format="webp"
            width={220}
            height={220}
            loading="lazy"
            decoding="async"
          />
          <span class="thumb-caption">{d.title}</span>
        </a>
      ))}
    </div>
  </div>
</Base>

<style>
  .container {
    max-width: 1140px;
    margin: 0 auto;
    padding: 64px 32px;
  }

  .gallery-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    border-bottom: 2px solid var(--char);
    padding-bottom: 12px;
    margin-bottom: 32px;
  }

  .gallery-title {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    font-size: clamp(40px, 6vw, 80px);
    line-height: 0.88;
    letter-spacing: -0.012em;
    margin: 0;
    color: var(--char);
  }

  .gallery-blurb {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 17px;
    color: var(--umber);
    max-width: 42ch;
    margin: 0 0 6px;
    text-align: right;
    line-height: 1.4;
  }

  .thumb-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 2px;
    background: var(--char);
    border: 2px solid var(--char);
  }

  .thumb-item {
    display: block;
    position: relative;
    overflow: hidden;
    background: var(--gallery-paper);
    text-decoration: none;
    color: var(--char);
    aspect-ratio: 1;
  }
  .thumb-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity 220ms cubic-bezier(.2,.8,.2,1);
    opacity: 0.85;
  }
  .thumb-item:hover img { opacity: 1; }

  .thumb-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 20px 10px 8px;
    font-family: var(--font-body);
    font-style: italic;
    font-size: 13px;
    color: var(--sepia);
    /* Subtle fade so caption reads over image */
    background: linear-gradient(to bottom, transparent, rgba(234, 215, 179, 0.9));
    opacity: 0;
    transition: opacity 220ms cubic-bezier(.2,.8,.2,1);
    line-height: 1.3;
  }
  .thumb-item:hover .thumb-caption { opacity: 1; }

  @media (max-width: 600px) {
    .container { padding: 40px 16px; }
    .gallery-head { flex-direction: column; align-items: flex-start; gap: 10px; }
    .gallery-blurb { text-align: left; max-width: none; }
  }
</style>
