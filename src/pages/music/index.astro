---
/**
 * Music page — mean spirit'd robots album layout.
 *
 * Layout: 2-col (280px cover, 1fr tracks).
 * Cover: char bg with diagonal 135deg flamingo/bone stripes at 25% opacity + band name.
 * Track list: bordered box, each row Silkscreen track number + Newsreader title + duration.
 * No real audio. Italic Newsreader sepia caption below grid.
 */

import Base from '../../layouts/Base.astro';
import SectionHead from '../../components/SectionHead.astro';
import { getCollection } from 'astro:content';

const records = await getCollection('music');
const record = records[0]; // single-doc collection
---

<Base
  title="music · hello, zito."
  description="mean spirit'd robots — a four-track band from the late 90s. demos, not products. by Tony Zito."
  current="music"
>
  <div class="container">
    <SectionHead
      title="music"
      blurb="a recovery project. a four-track band I had in the late 90s named “mean spirit'd robots”. these are demos, not products."
    />

    {record && (
      <div class="music-deck">
        <!-- Cover block -->
        <div class="cover-col">
          <div class="music-cover">
            <div class="stripes" aria-hidden="true"></div>
            <span class="band-name">{record.data.title}</span>
          </div>
          <div class="record-meta">
            <div class="record-label-line">demo cassette · {record.data.year}</div>
            <div class="record-sub">{record.data.label}</div>
            {record.data.soundcloudUrl && (
              <a
                class="btn"
                href={record.data.soundcloudUrl}
                target="_blank"
                rel="noreferrer"
              >
                open on soundcloud →
              </a>
            )}
          </div>
        </div>

        <!-- Track list -->
        <div class="track-list">
          {record.data.tracks.map((track) => (
            <div class="track">
              <span class="t-no">{track.n}</span>
              <span class="t-title">{track.title}</span>
              {track.duration && (
                <span class="t-len">{track.duration}</span>
              )}
            </div>
          ))}
        </div>
      </div>

      <p class="caption-hand">{record.data.caption}</p>
    )}
  </div>
</Base>

<style>
  .container {
    max-width: 1140px;
    margin: 0 auto;
    padding: 64px 32px;
  }

  .music-deck {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 32px;
    align-items: start;
  }

  /* Cover block */
  .cover-col {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .music-cover {
    aspect-ratio: 1;
    background: var(--char);
    border: 2px solid var(--char);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    isolation: isolate;
  }

  /* Diagonal flamingo/bone stripes at 25% opacity */
  .stripes {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      135deg,
      var(--flamingo) 0 18px,
      var(--bone) 18px 36px
    );
    opacity: 0.25;
  }

  .band-name {
    position: relative;
    z-index: 2;
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    font-size: 38px;
    line-height: 0.85;
    color: var(--bone);
    text-align: center;
    letter-spacing: -0.015em;
    padding: 18px;
  }

  .record-meta {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .record-label-line {
    font-family: var(--font-display);
    font-weight: 800;
    text-transform: uppercase;
    font-size: 13px;
    letter-spacing: 0.08em;
    color: var(--char);
  }

  .record-sub {
    font-family: var(--font-pixel);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--silt);
  }

  .btn {
    font-family: var(--font-display);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 13px;
    padding: 10px 16px;
    background: transparent;
    color: var(--char);
    border: 2px solid var(--char);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    margin-top: 6px;
    align-self: flex-start;
    transition: background 220ms cubic-bezier(.2,.8,.2,1), color 220ms;
  }
  .btn:hover {
    background: var(--char);
    color: var(--bone);
  }

  /* Track list */
  .track-list {
    border: 2px solid var(--char);
    background: var(--bone);
  }

  .track {
    display: grid;
    grid-template-columns: 36px 1fr auto;
    align-items: center;
    gap: 14px;
    padding: 12px 18px;
    border-bottom: 1.5px solid var(--linen);
  }
  .track:last-child { border-bottom: 0; }

  .t-no {
    font-family: var(--font-pixel);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--silt);
    text-align: center;
  }

  .t-title {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.3;
    color: var(--char);
  }

  .t-len {
    font-family: var(--font-pixel);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--silt);
    white-space: nowrap;
  }

  /* Caption in Newsreader italic sepia */
  .caption-hand {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 15px;
    color: var(--sepia);
    margin-top: 24px;
    text-align: center;
    line-height: 1.4;
  }

  @media (max-width: 720px) {
    .music-deck {
      grid-template-columns: 1fr;
    }
    .music-cover {
      max-width: 280px;
    }
  }

  @media (max-width: 600px) {
    .container { padding: 40px 20px; }
  }
</style>
